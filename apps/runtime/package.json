{
  "name": "@agentforge/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "pretest": "npm run build --workspace @agentforge/core && npm run build --workspace @agentforge/payments",
    "test": "vitest run",
    "pretypecheck": "npm run build --workspace @agentforge/core && npm run build --workspace @agentforge/payments",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify:runtime": "node scripts/verify-runtime-contract.mjs"
  },
  "dependencies": {
    "@agentforge/core": "file:../../packages/core",
    "@agentforge/payments": "file:../../packages/payments",
    "@okxweb3/x402-core": "^0.1.0",
    "@okxweb3/x402-evm": "^0.2.1",
    "@okxweb3/x402-express": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
