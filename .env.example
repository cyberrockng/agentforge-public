# Runtime identity
NODE_ENV=production
HOST=0.0.0.0
PORT=4010
MODEL_CLIENT=anthropic

# Model provider
ANTHROPIC_API_KEY=

# OKX x402 facilitator credentials
OKX_X402_API_KEY=
OKX_X402_SECRET_KEY=
OKX_X402_PASSPHRASE=

# x402 settlement wallet. Must be a 0x EVM address on X Layer.
AGENTFORGE_SETTLEMENT_ADDRESS=

# Runtime persistence. Recommended production mode is postgres.
AGENTFORGE_STORAGE_MODE=postgres
DATABASE_URL=
AGENTFORGE_DATABASE_MAX_CONNECTIONS=5
# Optional PGSSLMODE-compatible override, for example require or verify-full.
AGENTFORGE_DATABASE_SSL_MODE=

# JSONL fallback. Use single-instance-jsonl only with one runtime replica.
AGENTFORGE_RUNTIME_REPLICA_COUNT=1
AGENTFORGE_LEDGER_PATH=/data/agentforge/service-ledger.jsonl
AGENTFORGE_DELIVERY_ARCHIVE_DIR=/data/agentforge/delivery-archive
AGENTFORGE_PAYMENT_QUOTE_DIR=/data/agentforge/payment-quotes

# Optional runtime controls
AGENTFORGE_INTERNAL_TOKEN=
AGENTFORGE_QA_TOKEN=
AGENTFORGE_TRUSTED_CLIENT_IP_HEADER=
AGENTFORGE_SERVICE_RATE_LIMIT_WINDOW_MS=60000
AGENTFORGE_SERVICE_RATE_LIMIT_MAX=30
AGENTFORGE_SERVICE_RATE_LIMIT_MAX_BUCKETS=10000
